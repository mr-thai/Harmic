@model Harmic.Models.TbOrder
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
    decimal SubTotal() => Model?.TbOrderDetails?.Sum(d => (d.Price ?? 0m) * (d.Quantity ?? 0)) ?? 0m;
}
<!-- Begin Main Content Area -->
<main class="main-content">
    <div class="breadcrumb-area breadcrumb-height" data-bg-image="assets/images/breadcrumb/bg/1-1-1920x373.jpg">
        <div class="container h-100">
            <div class="row h-100">
                <div class="col-lg-12">
                    <div class="breadcrumb-item">
                        <h2 class="breadcrumb-heading">Product Related</h2>
                        <ul>
                            <li>
                                <a href="index.html">Home <i class="pe-7s-angle-right"></i></a>
                            </li>
                            <li>Cart</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="cart-area section-space-y-axis-100">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <div class="table-content table-responsive">
                        <table class="table" id="cart-table">
                            <thead>
                                <tr>
                                    <th class="product_remove">remove</th>
                                    <th class="product-thumbnail">images</th>
                                    <th class="cart-product-name">Product</th>
                                    <th class="product-price">Unit Price</th>
                                    <th class="product-quantity">Quantity</th>
                                    <th class="product-subtotal">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model?.TbOrderDetails != null && Model.TbOrderDetails.Any())
                                {
                                    foreach (var item in Model.TbOrderDetails)
                                    {
                                        var unitPrice = item.Price ?? 0m;
                                        var qty = item.Quantity ?? 0;
                                        var lineTotal = unitPrice * qty;
                                        <tr data-product-id="@item.ProductId">
                                            <td class="product_remove">
                                                <form asp-controller="Cart" asp-action="Remove" method="post" class="d-inline">
                                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                                    <button type="submit" class="btn btn-link p-0 m-0 align-baseline" title="Remove">
                                                        <i class="pe-7s-close"></i>
                                                    </button>
                                                </form>
                                            </td>
                                            <td class="product-thumbnail">
                                                <a href="javascript:void(0)">
                                                    <img src="assets/images/product/small-size/1-1-112x124.jpg" alt="Cart Thumbnail" />
                                                </a>
                                            </td>
                                            <td class="product-name">
                                                <a href="javascript:void(0)">Product #@item.ProductId</a>
                                            </td>
                                            <td class="product-price">
                                                <span class="amount">$@unitPrice.ToString("N0")</span>
                                            </td>
                                            <td class="quantity">
                                                <form asp-controller="Cart" asp-action="Update" method="post" class="cart-plus-minus d-inline-flex">
                                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                                    <input class="cart-plus-minus-box" name="quantity" value="@qty" type="number" min="0" />
                                                    <button type="submit" class="btn btn-sm btn-outline-secondary ms-2">Update</button>
                                                </form>
                                            </td>
                                            <td class="product-subtotal">
                                                <span class="amount">$@lineTotal.ToString("N0")</span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center">
                                            Your cart is empty.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-5 ms-auto">
                            <div class="cart-page-total">
                                <h2>Cart totals</h2>
                                <ul>
                                    <li>Subtotal <span>$@SubTotal().ToString("N0")</span></li>
                                    <li>Total <span>$@((Model?.TotalAmount ?? (int)SubTotal()).ToString("N0"))</span></li>
                                </ul>
                                <a asp-controller="VNplay"
                                   asp-action="CreatePaymentUrl"
                                   asp-route-moneyToPay="@(Convert.ToDouble(Model?.TotalAmount ?? (int)SubTotal()))"
                                   asp-route-description="Order payment">
                                    Proceed to checkout
                                </a>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</main>
<!-- Main Content Area End Here -->
<script>
    function payNow() {
        fetch('/Vnpay/Create?amount=100000&description=Thanh+toan+don+hang')
            .then(res => res.text())
            .then(url => {
                window.location.href = url; // <-- chuyển hướng sang VNPAY
            })
            .catch(err => alert(err));
    }
</script>