    <style>
        .chat-circle {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 62px;
            height: 62px;
            background-color: rgb(186, 195, 78);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 26px;
            box-shadow: 0 6px 14px rgba(0, 0, 0, 0.18);
            transition: 0.2s ease;
            z-index: 9999;
        }

            .chat-circle:hover {
                background: #78c878;
                transform: scale(1.06);
            }

        /* Hộp chat */
        .chat-box {
            position: fixed;
            bottom: 95px;
            right: 20px;
            width: 420px;
            max-height: 650px;
            background: #ffffff;
            border-radius: 14px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.25);
            display: none;
            flex-direction: column;
            overflow: hidden;
            z-index: 9999;
        }

        /* Header chat */
        .chat-header {
            background-color: rgb(186, 195, 78);
            color: white;
            padding: 12px;
            font-weight: bold;
            font-size: 15px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        /* Nội dung tin nhắn */
        .chat-messages {
            flex: 1;
            padding: 12px;
            display: flex;
            flex-direction: column;
            gap: 6px;
            overflow-y: auto;
            background: #f9f9f9;
        }

        /* Input chat */
        .chat-box input {
            border: none;
            border-top: 1px solid #ddd;
            padding: 10px;
            width: 100%;
            box-sizing: border-box;
        }
        /* message bubbles */
        .msg { padding: 8px 10px; border-radius: 8px; margin: 6px 0; max-width: 85%; word-wrap: break-word; }
        .msg-user { background:#e6f0ff; align-self:flex-end; margin-left:auto; }
        .msg-bot { background:#f5f5f5; align-self:flex-start; margin-right:auto; }
        .chat-messages { display:flex; flex-direction:column; }
        .chat-input-wrap { display:flex; border-top:1px solid #ddd; }
        .chat-input-wrap input { flex:1; }

        .chat-send-btn {
            border: none;
            background-color: rgb(186, 195, 78);
            color: #fff;
            padding: 0 14px;
        }
        .chat-typing { font-size:12px; color:#888; padding:4px 2px; }
    </style>
