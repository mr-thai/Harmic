    <script>
        const chatButton = document.getElementById('chatButton');
        const chatBox = document.getElementById('chatBox');
        const closeChat = document.getElementById('closeChat');

        const chatMessages = document.getElementById('chatMessages');
        const chatInput = document.getElementById('chatInput');
        const chatSend = document.getElementById('chatSend');

        chatButton.addEventListener('click', () => {
            chatBox.style.display = 'flex';
            chatButton.style.display = 'none';
            chatInput.focus();
        });

        closeChat.addEventListener('click', () => {
            chatBox.style.display = 'none';
            chatButton.style.display = 'flex';
        });

        function appendMsg(text, isBot) {
            const div = document.createElement('div');
            div.className = 'msg ' + (isBot ? 'msg-bot' : 'msg-user');
            div.textContent = text;
            chatMessages.appendChild(div);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        function appendTyping() {
            const d = document.createElement('div');
            d.className = 'chat-typing';
            d.id = 'typingDot';
            d.textContent = 'Đang soạn...';
            chatMessages.appendChild(d);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        function removeTyping() {
            const t = document.getElementById('typingDot');
            if (t) t.remove();
        }

        async function sendChat() {
            const text = chatInput.value.trim();
            if (!text) return;

            appendMsg(text, false);
            chatInput.value = '';
            appendTyping();

            try {
                const res = await fetch(`${window.location.origin}/ai/chat-api`, {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json',
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ prompt: text })
                });

                // Read as text first to avoid JSON parse errors on HTML error pages
                const raw = await res.text();
                let data;
                try { data = raw ? JSON.parse(raw) : {}; } catch { data = { response: raw }; }

                removeTyping();

                if (!res.ok) {
                    appendMsg(data.error || 'Có lỗi xảy ra. Vui lòng thử lại.', true);
                    return;
                }

                appendMsg(data.response || '...', true);
            } catch {
                removeTyping();
                appendMsg('Không thể kết nối máy chủ.', true);
            }
        }

        chatSend.addEventListener('click', sendChat);
        chatInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                sendChat();
            }
        });
    </script>
    <!--Main JS (Common Activation Codes)-->
    <script src="~/assets/js/main.js"></script>
    <script src="~/assets/toastr/toastr.min.js"></script>
    @RenderSection("Scripts", required: false)

    <!-- Anti-forgery token cho các gọi AJAX toàn cục -->
    <form id="af-token-form" style="display:none" method="post">
        @Html.AntiForgeryToken()
    </form>

    <!-- Mini-cart realtime (render từ /Cart/MiniCart) -->
    <script>
        function formatMoney(n) { try { return '$' + (n ?? 0).toLocaleString(); } catch { return '$' + n; } }
        function getAntiForgeryToken() {
            const el = document.querySelector('#af-token-form input[name="__RequestVerificationToken"]')
                   || document.querySelector('input[name="__RequestVerificationToken"]');
            return el ? el.value : '';
        }
        function cartRenderMiniCart(data) {
            const ul = document.getElementById('minicart-list');
            if (!ul) return;
            ul.innerHTML = '';
            (data.items || []).forEach(it => {
                const li = document.createElement('li');
                li.className = 'minicart-product';
                li.innerHTML = `
                    <a class="product-item_remove" href="#" data-remove-id="${it.productId}" title="Remove">
                        <i class="pe-7s-close"></i>
                    </a>
                    <a href="javascript:void(0)" class="product-item_img">
                        <img class="img-full" src="${it.imageUrl}" alt="Product Image">
                    </a>
                    <div class="product-item_content">
                        <a class="product-item_title" href="javascript:void(0)">${it.title}</a>
                        <span class="product-item_quantity">${it.quantity} x ${formatMoney(it.price)}</span>
                    </div>`;
                ul.appendChild(li);
            });

            const subtotal = document.getElementById('minicart-subtotal');
            if (subtotal) subtotal.textContent = formatMoney(data.subtotal || 0);

            const qtySpan = document.querySelector('.minicart-wrap .quantity');
            if (qtySpan) qtySpan.textContent = data.itemCount || 0;
        }
        async function cartReloadMiniCart() {
            try {
                const res = await fetch('@Url.Action("MiniCart","Cart")', { credentials: 'same-origin' });
                if (!res.ok) return;
                const data = await res.json();
                cartRenderMiniCart(data);
            } catch { /* noop */ }
        }
        async function cartPost(url, payload) {
            const token = getAntiForgeryToken();
            const body = new URLSearchParams({ __RequestVerificationToken: token, ...payload });
            const res = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                body
            });
            const data = await res.json().catch(() => ({}));
            if (data && data.itemCount != null) {
                const qtySpan = document.querySelector('.minicart-wrap .quantity');
                if (qtySpan) qtySpan.textContent = data.itemCount;
            }
            document.dispatchEvent(new CustomEvent('cart:changed', { detail: data }));
            return data;
        }

        document.addEventListener('DOMContentLoaded', () => {
            cartReloadMiniCart();
        });
        document.addEventListener('cart:changed', () => cartReloadMiniCart());

        // Xóa item ngay trong mini-cart (delegate click)
        document.addEventListener('click', async (e) => {
            const a = e.target.closest('a.product-item_remove[data-remove-id]');
            if (!a) return;
            e.preventDefault();
            const pid = a.getAttribute('data-remove-id');
            if (!pid) return;
            await cartPost('@Url.Action("RemoveAjax","Cart")', { productId: pid });
        });

        // Thêm sản phẩm vào giỏ hàng realtime (nút có data-add-cart)
        document.addEventListener('click', async (e) => {
            const btn = e.target.closest('[data-add-cart][data-product-id]');
            if (!btn) return;
            e.preventDefault();
            const pid = btn.getAttribute('data-product-id');
            // Mặc định qty = 1, có thể mở rộng đọc từ input bên cạnh
            await cartPost('@Url.Action("AddAjax","Cart")', { productId: pid, quantity: 1 });
        });
    </script>
</body>
